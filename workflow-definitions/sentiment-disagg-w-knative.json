{
    "Name": "sentiment",
    "Functions": {
        "SENTIMENT_CFAIL": {
            "Registry": "sysdevtamu/sentiment-cfail:kn"
        },
        "SENTIMENT_DB": {
            "Registry": "sysdevtamu/sentiment-db:kn"
        },
        "SENTIMENT_MAIN": {
            "Registry": "sysdevtamu/sentiment-main:kn",
            "Endpoints": ["SENTIMENT_READ_CSV"]
        },
        "SENTIMENT_PRODUCT_OR_SERVICE": {
            "Registry": "sysdevtamu/sentiment-product-or-service:kn",
            "Endpoints": ["SENTIMENT_CFAIL", "SENTIMENT_PRODUCT_SENTIMENT", "SENTIMENT_SERVICE_SENTIMENT"]
        },
        "SENTIMENT_PRODUCT_RESULT": {
            "Registry": "sysdevtamu/sentiment-product-result:kn",
            "Endpoints": ["SENTIMENT_SFAIL", "SENTIMENT_SNS", "SENTIMENT_DB"]
        },
        "SENTIMENT_PRODUCT_SENTIMENT": {
            "Registry": "sysdevtamu/sentiment-product-sentiment:kn",
            "Endpoints": ["SENTIMENT_PRODUCT_RESULT"]
        },
        "SENTIMENT_READ_CSV": {
            "Registry": "sysdevtamu/sentiment-read-csv:kn",
            "Endpoints": ["SENTIMENT_PRODUCT_OR_SERVICE"],
            "Envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"}
        },
        "SENTIMENT_SERVICE_RESULT": {
            "Registry": "sysdevtamu/sentiment-service-result:kn",
            "Endpoints": ["SENTIMENT_SFAIL", "SENTIMENT_SNS", "SENTIMENT_DB"]
        },
        "SENTIMENT_SERVICE_SENTIMENT": {
            "Registry": "sysdevtamu/sentiment-service-sentiment:kn",
            "Endpoints": ["SENTIMENT_SERVICE_RESULT"]
        },
        "SENTIMENT_SFAIL": {
            "Registry": "sysdevtamu/sentiment-sfail:kn"
        },
        "SENTIMENT_SNS": {
            "Registry": "sysdevtamu/sentiment-sns:kn",
            "Endpoints": ["SENTIMENT_DB"]
        }
    },
    "Payloads": [
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review.csv"}}}]},
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review2.csv"}}}]},
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review3.csv"}}}]},
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review4.csv"}}}]},
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review5.csv"}}}]},
        {"Records": [{"s3": {"bucket": {"name": "workflow-full-bucket"}, "object":{"key": "review6.csv"}}}]}
    ],
    "Config": {
        "Namespace": "knative-functions",
        "DeploymentType": "knative",
        "CommunicationType": "knative",
        "AggregationType": "disagg",
    },
    "Eval": {
        "Name": "sentiment-disagg-w-knative",
        "InvocationConcurrencies": [5, 10, 20, 40, 80, 100],
        "Invocations": 1000
    }
}
