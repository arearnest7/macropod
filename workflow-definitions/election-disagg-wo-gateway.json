{
    "Name": "election",
    "Functions": {
        "ELECTION_GATEWAY": {
            "Registry": "sysdevtamu/election-gateway:latest",
            "Endpoints": ["ELECTION_GET_RESULTS", "ELECTION_VOTE_ENQUEUER"]
        },
        "ELECTION_GET_RESULTS": {
            "Registry": "sysdevtamu/election-get-results:latest",
            "Envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"}
        },
        "ELECTION_VOTE_ENQUEUER": {
            "Registry": "sysdevtamu/election-vote-enqueuer:latest",
            "Endpoints": ["ELECTION_VOTE_PROCESSOR"],
            "Envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"}
        },
        "ELECTION_VOTE_PROCESSOR": {
            "Registry": "sysdevtamu/election-vote-processor:latest",
            "Envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"}
        }
    },
    "Payloads": [
        {"requestType": "vote", "id": "1234", "state": "TX", "candidate": "John_Smith"},
        {"requestType": "get_results"}
    ],
    "Config": {
        "DeploymentType": "macropod",
        "CommunicationType": "direct",
        "AggregationType": "disagg",
    },
    "Eval": {
        "Name": "election-disagg-wo-gateway",
        "InvocationConcurrencies": [5, 10, 20, 40, 80, 100],
        "Invocations": 1000
    }
}
