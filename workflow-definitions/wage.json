			"envs": {},
			"secrets": {}
		},
		"WAGE_WRITE_MERIT": {
			"registry": "sysdevtamu/wage-write-merit:macropod-http",
			"endpoints": [],
			"envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"},
			"secrets": {}
		},
		"WAGE_WRITE_RAW": {
			"registry": "sysdevtamu/wage-write-raw:macropod-http",
			"endpoints": ["WAGE_STATS"],
			"envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"},
			"secrets": {}
		}
	}
