{
	"workflow": "wage",
	"functions": {
		"WAGE_AVG": {
			"registry": "sysdevtamu/wage-avg:macropod-http",
			"endpoints": ["WAGE_MERIT"],
			"envs": {},
			"secrets": {}
		},
		"WAGE_FORMAT": {
			"registry": "sysdevtamu/wage-format:macropod-http",
			"endpoints": ["WAGE_WRITE_RAW"],
			"envs": {},
			"secrets": {}
		},
		"WAGE_MERIT": {
			"registry": "sysdevtamu/wage-merit:macropod-http",
			"endpoints": ["WAGE_WRITE_MERIT"],
			"envs": {},
			"secrets": {}
		},
		"WAGE_STATS": {
			"registry": "sysdevtamu/wage-stats:macropod-http",
			"endpoints": ["WAGE_SUM"],
			"envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"},
			"secrets": {}
		},
		"WAGE_SUM": {
			"registry": "sysdevtamu/wage-sum:macropod-http",
