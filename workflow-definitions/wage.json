			"envs": {},
			"secrets": {}
		},
		"wage-merit": {
			"registry": "arearnest7/wage-merit:macropod",
			"endpoints": ["wage-write-merit"],
			"envs": {},
			"secrets": {}
		},
		"wage-stats": {
			"registry": "arearnest7/wage-stats:macropod",
