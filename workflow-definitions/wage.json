			"registry": "arearnest7/wage-write-merit:macropod",
			"endpoints": [],
			"envs": {"REDIS_URL": "127.0.0.1", "REDIS_PASSWORD": "password"},
			"secrets": {}
		},
		"wage-write-raw": {
			"registry": "arearnest7/wage-write-raw:macropod",
